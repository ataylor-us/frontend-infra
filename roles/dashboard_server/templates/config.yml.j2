        url: "https://{{ tailscale_domain }}:{{ homeassistant_external_port }}"
        target: "_blank"
  - name: "Identity"
    icon: "fas fa-id-card"
    items:
      - name: "LLDAP"
        subtitle: "Directory"
        url: "https://{{ tailscale_domain }}:{{ lldap_external_port }}"
        target: "_blank"
      - name: "Authelia"
        subtitle: "Authentication"
        url: "https://{{ tailscale_domain }}:{{ authelia_external_port }}"
        target: "_blank"
