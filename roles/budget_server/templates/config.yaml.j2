# Populated by the find task in configure.yml.  borgmatic does sqlite3 .backup on each for consistency.
sqlite_databases:
{% for db in actual_sqlite_dbs.files %}
    - name: '{{ db.path | basename | regex_replace("\.sqlite$", "") }}'
      path: '{{ db.path }}'
{% endfor %}
repositories:
    - path: '{{ remote_borg_repo_path }}'
      label: "remote"
{% if lan_borg_repo is defined %}
    - path: '/misc/borg/{{ inventory_hostname }}'
      label: "lan"
{% endif %}
compression: lz4
encryption_passphrase: '{{ borg_passphrase }}'
archive_name_format: 'actual-{hostname}-{now:%Y-%m-%d-%H%M%S}'
read_special: true
retries: 5
retry_wait: 5
keep_within: 10d
keep_daily: 5
keep_weekly: 4
keep_monthly: 3
keep_yearly: 2
